# aac-cloud-api Lambda env template (dev)
# Copy, fill values, then apply with:
# aws lambda update-function-configuration \
#   --function-name aac-dev-cloud-api \
#   --environment "Variables={$(paste -sd, < this-file-without-comments)}"

# Core tables
OWNERSHIP_TABLE=aac-dev-device-ownership
STATE_TABLE=aac-dev-device-state
USER_DEVICES_TABLE=aac-dev-user-devices
INVITES_TABLE=aac-dev-device-invites
INTEGRATION_LINKS_TABLE=aac-dev-integration-links

# GSIs
OWNERSHIP_BY_OWNER_GSI=byOwnerUserId
USER_DEVICES_BY_DEVICE_GSI=byDeviceId
INVITES_BY_DEVICE_GSI=byDeviceId
INTEGRATION_LINKS_BY_DEVICE_GSI=byDeviceId

# IoT
IOT_ENDPOINT=xxxxxxxxxxxxxx-ats.iot.eu-central-1.amazonaws.com
THING_NAME_PREFIX=aac-
IOT_THING_ARN_PREFIX=arn:aws:iot:eu-central-1:123456789012:thing/
AWS_ACCOUNT_ID=123456789012

# Optional feature tables
CMD_IDEMPOTENCY_TABLE=aac-dev-cmd-idempotency
AUDIT_TABLE=aac-dev-audit
RATE_LIMIT_TABLE=aac-dev-rate-limit

# Security / feature flags
CLAIM_PROOF_REQUIRED=1
FEATURE_INVITES=1
FEATURE_SIGNED_INVITES=1
INVITE_TOKEN_SECRET=replace-with-strong-secret-min-16-chars
FEATURE_RATE_LIMIT=1
FEATURE_IDEMPOTENCY=1
FEATURE_CLAIM_PROOF=1
FEATURE_CLAIM_AUTO_BOOTSTRAP=1
FEATURE_SHADOW_STATE=1
FEATURE_SHADOW_DESIRED=1
FEATURE_SHADOW_ACL_SYNC=1
FEATURE_OTA_JOBS=1

# Tuning
CMD_IDEMPOTENCY_TTL_SEC=300
AUDIT_TTL_SEC=2592000
CMD_RATE_LIMIT_WINDOW_SEC=10
CMD_RATE_LIMIT_MAX=20
CLAIM_PROOF_SYNC_RATE_LIMIT_WINDOW_SEC=60
CLAIM_PROOF_SYNC_RATE_LIMIT_MAX=6
OTA_JOB_TARGET_SELECTION=SNAPSHOT
